# Anthropic API for Claude analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: specify Claude model (defaults to claude-3-haiku-20240307)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# URLScan.io API for domain trust checks
URLSCAN_API_KEY=your_urlscan_api_key_here

# WHOIS API for domain age verification
WHOIS_API_KEY=your_whois_api_key_here

# Frontend URL for CORS (optional - used for custom domains)
# Leave blank to allow chrome-extension://* and *.netlify.app by default
# Set to specific URL for additional allowed origin (e.g., custom domain)
FRONTEND_URL=

# Examples:
# FRONTEND_URL=https://pricecheck.yourdomain.com
# FRONTEND_URL=chrome-extension://your-specific-extension-id
